<main class="page page--chat">
    <div class="chat-shell">
        <header class="chat-header">
            <h1>Hola <span class="chat-user">{{user}}</span>!</h1>
        </header>
        <div id="chat-box"></div>
        <form class="chat-composer">
            <input type="text" name="message" placeholder="Escribí un mensaje…">
            <button type="submit">Enviar</button>
        </form>
    </div>
</main>
